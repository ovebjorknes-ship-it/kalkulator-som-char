  function calculateSavingsResult(){
    const annualPurchase = Number(answers.purchaseVolume) || 0;
    const maverickPercent = Number(answers.maverickSpend) || 0;
    const ordersPerMonth = Number(answers.ordersPerMonth) || 0;
    const users = estimateUsersFromBand(answers.employees);

    const maverickSavings = annualPurchase * (maverickPercent / 100) * SAVINGS_INPUTS.maverickMarkup;
    const processSavings = (ordersPerMonth * 12) * (SAVINGS_INPUTS.manualPoCost - SAVINGS_INPUTS.digitalPoCost);

    const hoursSavedPerWeekPerUser = (ordersPerMonth / 4) * (SAVINGS_INPUTS.timeSavedPerOrderMinutes / 60);
    const hoursSavedPerYear = hoursSavedPerWeekPerUser * SAVINGS_INPUTS.workWeeksPerYear * users;
    const timeSavings = hoursSavedPerYear * SAVINGS_INPUTS.hourlyCostWithOverhead;

    const duplicateSavings = annualPurchase * SAVINGS_INPUTS.duplicateRate * SAVINGS_INPUTS.duplicateReduction;
    const totalSavings = maverickSavings + processSavings + timeSavings + duplicateSavings;

    return {
      maverickSavings,
      processSavings,
      timeSavings,
      duplicateSavings,
      totalSavings,
      hoursSavedPerYear,
      users
    };
  }

  function animateCountUp(element, target, durationMs = 1600){
    const from = 0;
    const start = performance.now();

    function tick(now){
      const p = Math.min((now - start) / durationMs, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      const value = Math.round(from + (target - from) * eased);
      element.textContent = formatNok(value);
      if (p < 1) requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }

  async function sendReportRequest(payload){
    if (!REPORT_API_ENDPOINT) {
      throw new Error('REPORT_API_NOT_CONFIGURED');
    }

    const res = await fetch(REPORT_API_ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });

    if (!res.ok) {
      throw new Error(`REPORT_REQUEST_FAILED_${res.status}`);
    }

    return res;
  }

