  function scrollToBottom(){
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    chat.scrollTo({ top: chat.scrollHeight, behavior: reduce ? 'auto' : 'smooth' });
    postEmbedHeight();
  }
  function updateProgress(){
    const done = Math.max(0, currentStep);
    progressText.textContent = (done > 0) ? `Fremdrift: ${done}/${steps.length} spørsmål besvart` : '';
  }

  function addBotRow(content){
    const row = document.createElement('div');
    row.className = 'row bot';

    const img = document.createElement('img');
    img.className = 'avatar bot';
    img.alt = 'easyReq';
    img.src = AVATAR_BOT_URL || FALLBACK_BOT;
    row.appendChild(img);

    const bubble = document.createElement('div');
    bubble.className = 'msg bot';
    if (typeof content === 'string') bubble.innerHTML = content;
    else bubble.appendChild(content);
    row.appendChild(bubble);

    chat.appendChild(row);
    scrollToBottom();
    return bubble;
  }

  function addUserRow(text){
    const row = document.createElement('div');
    row.className = 'row user';

    const bubble = document.createElement('div');
    bubble.className = 'msg user';
    bubble.textContent = text;
    row.appendChild(bubble);

    const img = document.createElement('img');
    img.className = 'avatar user';
    img.alt = 'Besøkende';
    img.src = AVATAR_USER_URL || FALLBACK_USER;
    row.appendChild(img);

    chat.appendChild(row);
    scrollToBottom();
  }

  function typingBubble(){
    const row = document.createElement('div');
    row.className = 'row bot';

    const img = document.createElement('img');
    img.className = 'avatar bot';
    img.alt = 'easyReq';
    img.src = AVATAR_BOT_URL || FALLBACK_BOT;
    row.appendChild(img);

    const bubble = document.createElement('div');
    bubble.className = 'msg bot';
    const t = document.createElement('div');
    t.className = 'typing';
    t.innerHTML = '<span class="dot"></span><span class="dot"></span><span class="dot"></span>';
    bubble.appendChild(t);
    row.appendChild(bubble);

    chat.appendChild(row);
    scrollToBottom();
    return ()=> row.remove();
  }

  async function botSay(html, delayMs=350, isQuestion=false){
    const stop = typingBubble();
    await sleep(delayMs);
    stop();
    const bubble = addBotRow(html);
    if (isQuestion) bubble.classList.add('question');
  }

  async function showStart(){
    await botSay('Hei! 👋 La oss starte med noen kjappe spørsmål.');
    const actions = document.createElement('div');
    actions.className = 'actions';

    const btn = document.createElement('button');
    btn.className = 'btn primary';
    btn.textContent = 'Start';
    btn.addEventListener('click', ()=> askNext());

    actions.appendChild(btn);
    addBotRow('Trykk start når du er klar.');
    chat.appendChild(actions);
    scrollToBottom();
  }

  async function askNext(){
    currentStep++;
    updateProgress();

    if (currentStep >= steps.length){
      await showSavingsResult();
      await showRestart();
      return;
    }

    const s = steps[currentStep];

    if (s.type === 'dropdown'){
      await botSay(s.question, 350, true);

      const wrap = document.createElement('div');
      wrap.className = 'inline-form';
      wrap.style.alignSelf = 'flex-end';
      wrap.style.marginRight = 'var(--er-side-pad)';

      const select = document.createElement('select');
      select.setAttribute('aria-label', s.label);

      const placeholder = document.createElement('option');
      placeholder.value = '';
      placeholder.textContent = 'Velg...';
      placeholder.disabled = true;
      placeholder.selected = true;
      select.appendChild(placeholder);

      INDUSTRIES.forEach(ind=>{
        const opt = document.createElement('option');
        opt.value = ind;
        opt.textContent = ind;
        select.appendChild(opt);
      });

      const send = document.createElement('button');
      send.className = 'btn primary';
      send.textContent = 'OK';

      async function submit(){
        const v = select.value;
        if (!v) return;
        answers[s.id] = v;
        addUserRow(`${s.label}: ${v}`);
        await sleep(120);
        askNext();
      }

      send.addEventListener('click', submit);
      wrap.appendChild(select);
      wrap.appendChild(send);

      chat.appendChild(wrap);
      scrollToBottom();
      return;
    }

    if (s.type === 'boxes'){
      await botSay(s.question, 350, true);

      const actions = document.createElement('div');
      actions.className = 'actions';

      const grid = document.createElement('div');
      grid.className = 'box-grid';

      let selected = answers[s.id] || null;

      function setSelected(id){
        selected = id;
        answers[s.id] = id;
        grid.querySelectorAll('.box').forEach(el=>{
          el.classList.toggle('selected', el.dataset.id === id);
        });
      }

      EMPLOYEE_BANDS.forEach((band)=>{
        const btn = document.createElement('button');
        btn.className = 'box';
        btn.type = 'button';
        btn.dataset.id = band;
        btn.textContent = band;

        if (band === selected) btn.classList.add('selected');

        btn.addEventListener('click', async ()=>{
          setSelected(band);
          addUserRow(`${s.label}: ${band}`);
          await sleep(120);
          askNext();
        });

        grid.appendChild(btn);
      });

      actions.appendChild(grid);
      chat.appendChild(actions);
      scrollToBottom();
      return;
    }

    if (s.type === 'slider'){
      const industry = answers["industry"];
      const band = answers["employees"];

      const question = q3Question(industry);
      const defaultVal = q3Default(industry, band);

      await botSay(question, 350, true);
      await botSay(`<span class="meta">Forslag basert på bransje og hvor mange ansatte dere er: <b>${defaultVal}</b></span>`, 180);

      let value = Number.isFinite(answers[s.id]) ? Number(answers[s.id]) : defaultVal;

      const wrap = document.createElement('div');
      wrap.className = 'slider-wrap slider-wrap-right-mid';

      const top = document.createElement('div');
      top.className = 'slider-top';

      const k = document.createElement('div');
      k.className = 'k';
      k.textContent = 'Juster tallet';

      const v = document.createElement('div');
      v.className = 'v';
      v.textContent = String(value);

      top.appendChild(k);
      top.appendChild(v);

      const range = document.createElement('input');
      range.type = 'range';
      range.min = '0';
      range.max = String(q3SliderMax());
      range.step = '1';
      range.value = String(value);
      range.setAttribute('aria-label', question);

      range.addEventListener('input', ()=>{
        value = Number(range.value);
        v.textContent = String(value);
      });

      const send = document.createElement('button');
      send.className = 'btn primary';
      send.textContent = 'OK';

      send.addEventListener('click', async ()=>{
        answers[s.id] = Number(value);
        addUserRow(`${question}: ${value}`);
        await sleep(120);
        askNext();
      });

      wrap.appendChild(top);
      wrap.appendChild(range);
      wrap.appendChild(send);

      chat.appendChild(wrap);
      scrollToBottom();
      return;
    }

if (s.type === 'purchase_slider'){
      const industry = answers["industry"];
      const band = answers["employees"];

      const rangeText = purchaseRange(industry, band);
      const r = parseRangeToMinMax(rangeText);

      await botSay(s.question, 350, true);
      await botSay(`<span class="meta">Estimert intervall (basert på bransje og hvor mange ansatte dere er): <b>${rangeText || '—'}</b></span>`, 180);
      await botSay(`<span class="meta">Inkluder alle innkjøp av varer og tjenester — materialer, utstyr, forbruksmateriell, underleverandører.</span>`, 180);

      const min = r ? r.min : 0;
      const max = r ? r.max : 200000000;
      const step = 100000;

      let value = Number.isFinite(answers[s.id]) ? Number(answers[s.id]) : purchaseDefaultValue(industry, band);
      value = Math.max(min, Math.min(max, value));

      const wrap = document.createElement('div');
      wrap.className = 'slider-wrap slider-wrap-right-mid';

      const top = document.createElement('div');
      top.className = 'slider-top';

      const k = document.createElement('div');
      k.className = 'k';
      k.textContent = 'Juster verdien';

      const v = document.createElement('div');
      v.className = 'v';
      v.textContent = formatKr(value);

      top.appendChild(k);
      top.appendChild(v);

      const range = document.createElement('input');
      range.type = 'range';
      range.min = String(min);
      range.max = String(max);
      range.step = String(step);
      range.value = String(value);
      range.setAttribute('aria-label', s.label);

      function updateDisplays(newVal){
        value = newVal;
        v.textContent = formatKr(value);
        range.value = String(value);
      }

      range.addEventListener('input', ()=>{
        updateDisplays(Number(range.value));
      });

      const send = document.createElement('button');
      send.className = 'btn primary';
      send.textContent = 'OK';

      send.addEventListener('click', async ()=>{
        answers[s.id] = Number(value);
        addUserRow(`${s.label}: ${formatKr(value)}`);
        await sleep(120);
        askNext();
      });

      wrap.appendChild(top);
      wrap.appendChild(range);
      wrap.appendChild(send);

      chat.appendChild(wrap);
      scrollToBottom();
      return;
    }

    if (s.type === 'maverick_slider'){
      const industry = answers["industry"];
      const rangeText = maverickRange(industry);
      const r = parsePercentRange(rangeText);

      await botSay(s.question, 350, true);
      await botSay(`<span class="meta">Hvor mange av innkjøpene skjer uten forhåndsgodkjenning, uten rammeavtale eller via direkte kontakt med leverandør?</span>`, 180);
      await botSay(`<span class="meta">Typisk intervall for ${industry}: <b>${rangeText ? rangeText.replace('-', '–') + '%' : '—'}</b></span>`, 180);

      const min = r ? r.min : 0;
      const max = r ? r.max : 100;
      const step = 1;

      let value = Number.isFinite(answers[s.id]) ? Number(answers[s.id]) : maverickDefaultValue(industry);
      value = Math.max(min, Math.min(max, value));

      const wrap = document.createElement('div');
      wrap.className = 'slider-wrap slider-wrap-right-mid';

      const top = document.createElement('div');
      top.className = 'slider-top';

      const k = document.createElement('div');
      k.className = 'k';
      k.textContent = 'Juster prosentandel';

      const v = document.createElement('div');
      v.className = 'v';
      v.textContent = `${value}%`;

      top.appendChild(k);
      top.appendChild(v);

      const range = document.createElement('input');
      range.type = 'range';
      range.min = String(min);
      range.max = String(max);
      range.step = String(step);
      range.value = String(value);
      range.setAttribute('aria-label', s.label);

      range.addEventListener('input', ()=>{
        value = Number(range.value);
        v.textContent = `${value}%`;
      });

      const send = document.createElement('button');
      send.className = 'btn primary';
      send.textContent = 'OK';

      send.addEventListener('click', async ()=>{
        answers[s.id] = Number(value);
        addUserRow(`${s.label}: ${value}%`);
        await sleep(120);
        askNext();
      });

      wrap.appendChild(top);
      wrap.appendChild(range);
      wrap.appendChild(send);

      chat.appendChild(wrap);
      scrollToBottom();
      return;
    }

    if (s.type === 'orders_slider'){
      const industry = answers["industry"];
      const band = answers["employees"];
      const rateRange = ordersPerEmployeeRange(industry);
      const defaultVal = monthlyOrdersDefaultValue(industry, band);

      await botSay(s.question, 350, true);
      await botSay(`<span class="meta">Typisk for ${industry}: <b>${rateRange ? rateRange.replace('-', '–').replace(/\./g, ',') : '—'}</b> bestillinger per ansatt per måned</span>`, 180);
      await botSay(`<span class="meta">Estimert fra bransje og ansatte: <b>${defaultVal}</b> bestillinger/mnd</span>`, 180);

      let minOrders = defaultVal * 0.5;
      let maxOrders = defaultVal * 2.5;
      minOrders = Math.max(0, Math.round(minOrders));
      maxOrders = Math.round(maxOrders);

      let value = Number.isFinite(answers[s.id]) ? Number(answers[s.id]) : defaultVal;
      value = Math.max(minOrders, Math.min(maxOrders, value));

      const wrap = document.createElement('div');
      wrap.className = 'slider-wrap slider-wrap-right-mid';

      const top = document.createElement('div');
      top.className = 'slider-top';

      const k = document.createElement('div');
      k.className = 'k';
      k.textContent = 'Juster antall';

      const v = document.createElement('div');
      v.className = 'v';
      v.textContent = String(value);

      top.appendChild(k);
      top.appendChild(v);

      const range = document.createElement('input');
      range.type = 'range';
      range.min = String(minOrders);
      range.max = String(maxOrders);
      range.step = '1';
      range.value = String(value);
      range.setAttribute('aria-label', s.label);

      range.addEventListener('input', ()=>{
        value = Number(range.value);
        v.textContent = String(value);
      });

      const send = document.createElement('button');
      send.className = 'btn primary';
      send.textContent = 'OK';

      send.addEventListener('click', async ()=>{
        answers[s.id] = Number(value);
        addUserRow(`${s.label}: ${value}`);
        await sleep(120);
        askNext();
      });

      wrap.appendChild(top);
      wrap.appendChild(range);
      wrap.appendChild(send);

      chat.appendChild(wrap);
      scrollToBottom();
      return;
    }

    if (s.type === 'multiple_choice'){
      await botSay(s.question, 350, true);
      await botSay(`<span class="meta">Dersom dere har en kombinasjon kan dere velge flere av alternativene.</span>`, 180);

      const actions = document.createElement('div');
      actions.className = 'actions';
      actions.style.flexDirection = 'column';
      actions.style.alignItems = 'flex-end';
      actions.style.marginRight = 'var(--er-side-pad)';
      actions.style.width = '100%';

      const grid = document.createElement('div');
      grid.className = 'box-grid';

      let selectedChoices = answers[s.id] || [];
      if (!Array.isArray(selectedChoices)) selectedChoices = [];

      function toggleChoice(choice){
        const idx = selectedChoices.indexOf(choice);
        if (idx === -1){
          selectedChoices.push(choice);
        } else {
          selectedChoices.splice(idx, 1);
        }
        grid.querySelectorAll('.box').forEach(el=>{
          el.classList.toggle('selected', selectedChoices.includes(el.textContent));
        });
      }

      s.options.forEach((choice)=>{
        const btn = document.createElement('button');
        btn.className = 'box';
        btn.type = 'button';
        btn.textContent = choice;

        if (selectedChoices.includes(choice)) btn.classList.add('selected');

        btn.addEventListener('click', ()=>{
          toggleChoice(choice);
        });

        grid.appendChild(btn);
      });

      const send = document.createElement('button');
      send.className = 'btn primary';
      send.textContent = 'OK';
      send.style.marginTop = '8px';

      send.addEventListener('click', async ()=>{
        if (selectedChoices.length === 0) return;
        answers[s.id] = [...selectedChoices];
        const displayText = selectedChoices.join(', ');
        addUserRow(`${s.label}: ${displayText}`);
        await sleep(120);
        askNext();
      });

      actions.appendChild(grid);
      actions.appendChild(send);
      chat.appendChild(actions);
      scrollToBottom();
      return;
    }
  }

  async function showRestart(){
    const actions = document.createElement('div');
    actions.className = 'actions';

    const restart = document.createElement('button');
    restart.className = 'chip';
    restart.textContent = 'Start på nytt';
    restart.addEventListener('click', ()=>{
      chat.innerHTML = '';
      Object.keys(answers).forEach(k=>delete answers[k]);
      currentStep = -1;
      updateProgress();
      showStart();
    });

    actions.appendChild(restart);
    chat.appendChild(actions);
    scrollToBottom();
  }

  window.addEventListener('load', ()=> postEmbedHeight());
  window.addEventListener('resize', ()=> postEmbedHeight());

  const __embedResizeObserver = new MutationObserver(()=> postEmbedHeight());
  __embedResizeObserver.observe(document.body, { childList: true, subtree: true, attributes: true, characterData: true });

  (async function init(){
    await showStart();
    postEmbedHeight();
  })();
</script>
</body>
</html>