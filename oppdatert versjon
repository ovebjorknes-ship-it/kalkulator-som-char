  const NOK0 = new Intl.NumberFormat('nb-NO', { maximumFractionDigits: 0 });
  function formatKr(n){ return `${NOK0.format(Math.round(n))} kr`; }

  function parseRangeToMinMax(rangeText){
    if (!rangeText) return null;
    const parts = String(rangeText).split('–');
    if (parts.length !== 2) return null;
    const toNum = (s)=> Number(String(s).replace(/\s+/g,'').replace(/[^\d]/g,''));
    const min = toNum(parts[0]);
    const max = toNum(parts[1]);
    if (!Number.isFinite(min) || !Number.isFinite(max) || min <= 0 || max <= 0) return null;
    return { min, max };
  }

  function q3Question(industry){ return MATRIX_Q3[industry]?.question || 'Oppgi verdi'; }
  function q3Default(industry, band){ return MATRIX_Q3[industry]?.defaults?.[band] ?? 0; }
  function q3SliderMax(){ return 200; }

  function purchaseRange(industry, band){ return PURCHASE_MATRIX[industry]?.[band] || ''; }
  function purchaseDefaultValue(industry, band){
    const r = parseRangeToMinMax(purchaseRange(industry, band));
    if (!r) return 0;
    return Math.round((r.min + r.max) / 2);
  }

  function parsePercentRange(rangeText){
    if (!rangeText) return null;
    const parts = String(rangeText).split('-');
    if (parts.length !== 2) return null;
    const min = Number(parts[0]);
    const max = Number(parts[1]);
    if (!Number.isFinite(min) || !Number.isFinite(max) || min < 0 || max > 100 || min > max) return null;
    return { min, max };
  }

  function maverickRange(industry){ return MAVERICK_SPEND_MATRIX[industry] || ''; }

  function maverickDefaultValue(industry){
    const r = parsePercentRange(maverickRange(industry));
    if (!r) return 0;
    return Math.round((r.min + r.max) / 2);
  }

  function parseDecimalRange(rangeText){
    if (!rangeText) return null;
    const parts = String(rangeText).split('-');
    if (parts.length !== 2) return null;
    const min = Number(parts[0].replace(',', '.'));
    const max = Number(parts[1].replace(',', '.'));
    if (!Number.isFinite(min) || !Number.isFinite(max) || min < 0 || max < min) return null;
