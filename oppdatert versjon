<!doctype html>
<html lang="nb">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>easyReq – Chatkalkulator</title>

<style>
  :root{
    --er-primary: #ea5c0c;
    --er-accent:  #ea5c0c;
    --er-page-bg: #000000;

    --er-surface:   #111418;
    --er-surface-2: #161b21;
    --er-border:    #233044;
    --er-text:      #E5E7EB;
    --er-text-inv:  #FFFFFF;
    --er-muted:     #9AA6B2;

    --er-btn-radius: 10px;
    --er-bubble-radius: 16px;
    --er-chat-maxw: 1200px;
    --er-side-pad:  0.5%;
  }

  html, body { background:#000; }
  body {
    color:var(--er-text);
    margin:0;
    font-family:system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Cantarell,Noto Sans,sans-serif;
  }

  .container{max-width:100%;margin:0 auto;padding:24px}

  .tpb-hero{background:#000;color:var(--er-text);padding:48px 0}
  .tpb-hero h1{margin:0 0 10px 0}
  .tpb-hero p{margin:0}

  .chat-wrap{
    margin:24px auto 0 auto;
    border:1px solid var(--er-border);
    background:var(--er-surface);
    border-radius:14px;
    padding:12px;
    min-height:420px;
    display:flex; flex-direction:column;
    max-width:var(--er-chat-maxw);
    width:100%;
  }
  .chat{
    display:flex; flex-direction:column; gap:12px;
    padding:8px;
    overflow-y:auto;
    max-height:70vh;
  }

  .row{ display:flex; gap:10px; align-items:flex-end; }
  .row.bot{ justify-content:flex-start; margin-left: var(--er-side-pad); }
  .row.user{ justify-content:flex-end; margin-right: var(--er-side-pad); }

  .avatar{
    width:clamp(28px, 3.8vw, 44px);
    height:clamp(28px, 3.8vw, 44px);
    object-fit:cover; display:block; border:1px solid var(--er-border);
    background:#fff;
  }
  .avatar.bot{ border-radius:10px; }
  .avatar.user{ border-radius:50%; }

  .msg{
    max-width: 95%;
    padding:12px 14px;
    border:1px solid var(--er-border);
    border-radius: var(--er-bubble-radius);
    line-height: 1.5;
    word-wrap: break-word;
    white-space: pre-wrap;
  }
  .msg.bot{ background:var(--er-surface-2); color:var(--er-text); }
  .msg.bot.question{ font-size:16px; font-weight:600; }
  .msg.user{ background:var(--er-primary); color:var(--er-text-inv); border-color: transparent; }

  .actions{
    display:flex;
    gap:8px;
    flex-wrap:wrap;
    margin-top:8px;
    align-self:flex-end;
    margin-left: 0;
    margin-right: var(--er-side-pad);
    justify-content:flex-end;
  }

  .chip, .btn{
    cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; justify-content:center;
    border-radius: var(--er-btn-radius);
    transition: background-color .15s ease, color .15s ease, border-color .15s ease, box-shadow .15s ease, filter .15s ease;
    user-select:none;
    font: inherit;
  }
  .chip{
    background:transparent; color:var(--er-accent);
    border:1.5px solid var(--er-accent);
    padding:8px 12px;
  }
  .chip:hover{ background:rgba(234,92,12,0.12); border-color:#ff6b1e; box-shadow:0 0 0 3px rgba(234,92,12,0.18); }

  .btn.primary{
    background:var(--er-primary); color:#fff; border:0;
    padding:12px 16px;
  }
  .btn.primary:hover{ filter:brightness(0.92); box-shadow:0 0 0 3px rgba(234,92,12,0.18); }
  .btn.secondary{
    background:transparent;
    color:var(--er-accent);
    border:1.5px solid var(--er-accent);
    padding:12px 16px;
  }
  .btn.secondary:hover{
    background:rgba(234,92,12,0.12);
    border-color:#ff6b1e;
    box-shadow:0 0 0 3px rgba(234,92,12,0.18);
  }

  .inline-form{ display:flex; gap:8px; align-items:center; margin-top:8px; flex-wrap:wrap }
  .inline-form input, .inline-form select{
    padding:10px 12px;
    border:1px solid var(--er-border);
    border-radius:10px;
    background:var(--er-surface-2);
    color:var(--er-text);
    min-width:220px;
    text-align:center;
  }

  .meta{ font-size:12px; color:var(--er-muted) }

  .typing{ display:inline-flex; gap:6px; }
  .dot{ width:8px; height:8px; border-radius:50%; background:#9AA6B2; opacity:.6; animation: blink 1s infinite; }
  .dot:nth-child(2){ animation-delay: .15s }
  .dot:nth-child(3){ animation-delay: .3s }
  @keyframes blink { 0%,80%,100%{ opacity:.2 } 40%{ opacity:1 } }

  .chip:focus-visible, .btn:focus-visible, input:focus-visible, select:focus-visible, a:focus-visible {
    outline: 3px solid rgba(234,92,12,0.6);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce){
    .btn, .chip{ transition:none; }
    html{ scroll-behavior:auto; }
  }

  .box-grid{
    display:grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap:10px;
    width:min(560px, 100%);
  }
  @media (max-width:560px){
    .box-grid{ grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  .box{
    text-align:center;
    padding:12px 10px;
    border-radius:12px;
    border:1.5px solid var(--er-accent);
    color:var(--er-accent);
    background:transparent;
    font-weight:700;
    cursor:pointer;
    transition: background-color .15s ease, color .15s ease, box-shadow .15s ease, border-color .15s ease;
  }
  .box:hover{
    background:rgba(234,92,12,0.12);
    border-color:#ff6b1e;
    box-shadow:0 0 0 3px rgba(234,92,12,0.18);
  }
  .box.selected{
    background:rgba(234,92,12,0.18);
    color:#ffd9c6;
    border-color:#ff6b1e;
    box-shadow:0 0 0 3px rgba(234,92,12,0.18);
  }

  .slider-wrap{
    display:grid;
    gap:10px;
    padding:12px;
    border:1px solid var(--er-border);
    border-radius:12px;
    background:var(--er-surface-2);
    width:100%;
    max-width:100%;
    align-self:flex-end;
    margin-right: var(--er-side-pad);
  }
  .slider-wrap.slider-wrap-right-mid{
    width:48%;
    max-width:560px;
    min-width:320px;
    margin-left:auto;
  }
  @media (max-width:900px){
    .slider-wrap.slider-wrap-right-mid{
      width:100%;
      min-width:0;
    }
  }
  .slider-top{
    display:flex;
    justify-content:space-between;
    gap:12px;
    align-items:baseline;
  }
  .slider-top .k{ color:var(--er-muted); font-size:13px; }
  .slider-top .v{ font-weight:800; }
  input[type="range"]{ width:100%; }

  .result-wrap{
    display:grid;
    gap:12px;
    padding:14px;
    border:1px solid var(--er-border);
    border-radius:12px;
    background:var(--er-surface-2);
    width:100%;
    max-width:680px;
    align-self:flex-end;
    margin-right:var(--er-side-pad);
  }
  .result-head{
    display:grid;
    gap:6px;
    padding:10px;
    border:1px solid rgba(234,92,12,0.4);
    border-radius:10px;
    background:rgba(234,92,12,0.08);
  }
  .result-label{
    font-size:14px;
    color:var(--er-text);
    font-weight:700;
  }
  .result-total{
    font-size:clamp(28px, 4.2vw, 44px);
    line-height:1.1;
    font-weight:900;
    color:var(--er-primary);
    letter-spacing:0.2px;
  }
  .result-list{
    display:grid;
    gap:8px;
  }
  .result-item{
    display:flex;
    justify-content:space-between;
    gap:10px;
    padding:10px;
    border:1px solid var(--er-border);
    border-radius:10px;
    background:rgba(255,255,255,0.01);
  }
  .result-item .k{
    color:var(--er-text);
    font-size:14px;
  }
  .result-item .v{
    color:var(--er-text);
    font-weight:800;
    white-space:nowrap;
  }
  .result-note{
    font-size:12px;
    color:var(--er-muted);
  }
  .result-cta{
    font-size:14px;
    color:var(--er-text);
    padding:10px;
    border:1px solid rgba(234,92,12,0.35);
    border-radius:10px;
    background:rgba(234,92,12,0.06);
  }
  .lead-form{
    display:grid;
    gap:8px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .lead-form input,
  .lead-form select{
    width:100%;
    padding:10px 12px;
    border:1px solid var(--er-border);
    border-radius:10px;
    background:var(--er-surface);
    color:var(--er-text);
    box-sizing:border-box;
  }
  .lead-form .full{ grid-column:1 / -1; }
  .lead-form .submit-wrap{
    grid-column:1 / -1;
    display:flex;
    justify-content:flex-end;
    gap:8px;
  }
  .lead-form-msg{
    grid-column:1 / -1;
    font-size:12px;
    color:var(--er-muted);
  }
  @media (max-width:640px){
    .lead-form{ grid-template-columns: 1fr; }
  }
</style>
</head>

