  function ensureJsPdfLoaded(){
    if (window.jspdf && window.jspdf.jsPDF) return Promise.resolve(window.jspdf.jsPDF);
    if (window.__jspdfLoadingPromise) return window.__jspdfLoadingPromise;

    window.__jspdfLoadingPromise = new Promise((resolve, reject)=>{
      const script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js';
      script.async = true;
      script.onload = ()=>{
        if (window.jspdf && window.jspdf.jsPDF) resolve(window.jspdf.jsPDF);
        else reject(new Error('JSPDF_LOAD_FAILED'));
      };
      script.onerror = ()=> reject(new Error('JSPDF_LOAD_FAILED'));
      document.head.appendChild(script);
    });

    return window.__jspdfLoadingPromise;
  }

  function benchmarkStatus(value, min, max, lowerIsBetter = false){
    if (!Number.isFinite(value) || !Number.isFinite(min) || !Number.isFinite(max)) return 'Ingen benchmark tilgjengelig';
    if (value < min) return lowerIsBetter ? 'Bedre enn benchmark (lavere)' : 'Under benchmark';
    if (value > max) return lowerIsBetter ? 'Over benchmark (hoyere)' : 'Over benchmark';
    return 'Innenfor benchmark';
  }

  function buildBenchmarks(){
    const industry = answers.industry || 'Annet';
    const band = answers.employees || '1-10';
    const employees = EMPLOYEE_BAND_MIDPOINT[band] || 0;

    const purchaseUser = Number(answers.purchaseVolume) || 0;
    const purchaseTypical = parseRangeToMinMax(purchaseRange(industry, band));

    const maverickUser = Number(answers.maverickSpend) || 0;
    const maverickTypical = parsePercentRange(maverickRange(industry));

    const ordersUser = Number(answers.ordersPerMonth) || 0;
    const orderRateTypical = parseDecimalRange(ordersPerEmployeeRange(industry));
    const ordersTypical = orderRateTypical && employees > 0
      ? {
          min: Math.round(orderRateTypical.min * employees),
          max: Math.round(orderRateTypical.max * employees)
        }
      : null;

    const q3User = Number(answers.q3) || 0;
    const q3Typical = q3Default(industry, band);
    const q3QuestionLabel = q3Question(industry);

    return [
      {
        label: 'Arlig innkjopsvolum',
        user: purchaseUser > 0 ? formatNok(purchaseUser) : 'Ikke oppgitt',
        benchmark: purchaseTypical ? `${formatNok(purchaseTypical.min)} - ${formatNok(purchaseTypical.max)}` : 'Ingen benchmark',
        status: purchaseTypical ? benchmarkStatus(purchaseUser, purchaseTypical.min, purchaseTypical.max) : 'Ingen benchmark tilgjengelig'
      },
      {
        label: 'Ukontrollerte innkjop (maverick spend)',
        user: `${maverickUser}%`,
        benchmark: maverickTypical ? `${maverickTypical.min}% - ${maverickTypical.max}%` : 'Ingen benchmark',
        status: maverickTypical ? benchmarkStatus(maverickUser, maverickTypical.min, maverickTypical.max, true) : 'Ingen benchmark tilgjengelig'
      },
      {
        label: 'Bestillinger per maned (totalt)',
        user: `${NOK0.format(Math.round(ordersUser))} bestillinger`,
        benchmark: ordersTypical ? `${NOK0.format(ordersTypical.min)} - ${NOK0.format(ordersTypical.max)} bestillinger` : 'Ingen benchmark',
        status: ordersTypical ? benchmarkStatus(ordersUser, ordersTypical.min, ordersTypical.max) : 'Ingen benchmark tilgjengelig'
      },
      {
        label: q3QuestionLabel,
        user: `${NOK0.format(Math.round(q3User))}`,
        benchmark: `${NOK0.format(Math.round(q3Typical))} (typisk anslag)`,
        status: q3User > q3Typical ? 'Over typisk anslag' : (q3User < q3Typical ? 'Under typisk anslag' : 'Lik typisk anslag')
      }
    ];
  }

  function calcProfitMultiplier(totalSavings, annualPurchase, users){
    // Conservative proxy for annual implementation + subscription spend.
    const annualInvestment = Math.max(50000, Math.round((annualPurchase * 0.005) + (users * 12000)));
    const multiplier = annualInvestment > 0 ? (totalSavings / annualInvestment) : 0;
    return { annualInvestment, multiplier };
  }

