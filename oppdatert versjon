    const r = parseDecimalRange(ordersPerEmployeeRange(industry));
    const employees = EMPLOYEE_BAND_MIDPOINT[band] || 0;
    if (!r || employees <= 0) return 0;
    const midpointRate = (r.min + r.max) / 2;
    return Math.round(employees * midpointRate);
